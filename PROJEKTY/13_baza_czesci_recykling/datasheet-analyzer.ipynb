    "class DatasheetAIAnalyzer:\n",
    "    \"\"\"Analizuje PDF datasheety przez Gemini AI.\"\"\"\n",
    "    \n",
    "    def __init__(self, api_keys: List[str]):\n",
    "        self.clients = [genai.Client(api_key=k) for k in api_keys]\n",
    "        self.current_idx = 0\n",
    "        self.request_count = 0\n",
    "        self.start_time = time.time()\n",
    "    \n",
    "    def _get_client(self):\n",
    "        \"\"\"Round-robin z rate limiting.\"\"\"\n",
    "        # Sprawdź rate limit\n",
    "        elapsed = time.time() - self.start_time\n",
    "        if elapsed > 0 and self.request_count / (elapsed / 60) >= GEMINI_RPM - 2:\n",
    "            wait = 60 - (elapsed % 60) + 2\n",
    "            print(f'  ⏳ Rate limit — czekam {wait:.0f}s...')\n",
    "            time.sleep(wait)\n",
    "            self.start_time = time.time()\n",
    "            self.request_count = 0\n",
    "        \n",
    "        client = self.clients[self.current_idx]\n",
    "        self.current_idx = (self.current_idx + 1) % len(self.clients)\n",
    "        self.request_count += 1\n",
    "        return client\n",
    "    \n",
    "    def analyze_pdf(self, pdf_path: str, part_number: str) -> Dict[str, Any]:\n",
    "        \"\"\"Główna analiza datasheet PDF → ekstrakcja wszystkich parametrów.\"\"\"\n",
    "        client = self._get_client()\n",
    "        \n",
    "        try:\n",
    "            # Upload PDF do Gemini\n",
    "            print(f'  📤 Upload PDF do Gemini...')\n",
    "            pdf_file = client.files.upload(file=pdf_path)\n",
    "            \n",
    "            # Czekaj na processing\n",
    "            wait_count = 0\n",
    "            while pdf_file.state.name == 'PROCESSING':\n",
    "                time.sleep(2)\n",
    "                pdf_file = client.files.get(name=pdf_file.name)\n",
    "                wait_count += 1\n",
    "                if wait_count > 60:  # 2 min timeout\n",
    "                    raise TimeoutError('PDF processing timeout')\n",
    "            \n",
    "            if pdf_file.state.name == 'FAILED':\n",
    "                raise Exception(f'Gemini PDF processing failed: {pdf_file.state}')\n",
    "            \n",
    "            # ── PROMPT: Ekstrakcja parametrów ──\n",
    "            system_prompt = '''Jesteś inżynierem elektronikiem z 20-letnim doświadczeniem.\n",
    "Analizujesz datasheet PDF części elektronicznej.\n",
    "\n",
    "ZADANIE: Wyekstrahuj WSZYSTKIE techniczne parametry z datasheet.\n",
    "\n",
    "Zwróć TYLKO JSON w tym formacie:\n",
    "{\n",
    "  \"part_name\": \"Pełna nazwa części\",\n",
    "  \"manufacturer\": \"Producent\",\n",
    "  \"category\": \"Kategoria InvenTree (np. Capacitor, Resistor, IC, Transistor, Diode, Connector)\",\n",
    "  \"species\": \"Gatunek (np. Electrolytic, Ceramic, MOSFET, BJT, Zener, OpAmp, Voltage Regulator)\",\n",
    "  \"genus\": \"Rodzaj (np. Capacitor, Transistor, Diode, IC, Voltage Regulator)\",\n",
    "  \"mounting\": \"Montowanie (SMD/THT/BGA/QFN)\",\n",
    "  \"package\": \"Obudowa (np. SOT-23, SOIC-8, 0805, TO-220, DIP-8)\",\n",
    "  \"value\": \"Wartość (np. 10uF, 4.7kΩ, 3.3V)\",\n",
    "  \"tolerance\": \"Tolerancja (np. ±5%, ±10%, ±1%)\",\n",
    "  \"voltage_rating\": \"Napięcie nominalne/max\",\n",
    "  \"current_rating\": \"Prąd nominalny/max\",\n",
    "  \"power_rating\": \"Moc nominalna/max\",\n",
    "  \"temperature_range\": \"Zakres temperatur roboczych\",\n",
    "  \"description\": \"Krótki opis funkcji (1-2 zdania)\",\n",
    "  \"keywords\": \"słowa kluczowe, oddzielone przecinkami\",\n",
    "  \"pinout\": {\"1\": \"VCC\", \"2\": \"GND\", ...},\n",
    "  \"parameters\": {\"Param1\": \"Value1\", \"Param2\": \"Value2\", ...},\n",
    "  \"cross_references\": [\"zamiennik1\", \"zamiennik2\"],\n",
    "  \"application_notes\": \"Kluczowe informacje o zastosowaniu\",\n",
    "  \"safety_notes\": \"Ostrzeżenia, absolute max ratings\",\n",
    "  \"kicad_symbol\": \"Symbol KiCad jeśli znany\",\n",
    "  \"kicad_footprint\": \"Footprint KiCad jeśli znany\",\n",
    "  \"kicad_reference\": \"Reference designator (U, R, C, D, Q, L, J)\",\n",
    "  \"confidence\": 0.95\n",
    "}'''\n",
    "            \n",
    "            user_prompt = f'Przeanalizuj datasheet części: {part_number}'\n",
    "            \n",
    "            contents = [genai_types.Content(\n",
    "                role='user',\n",
    "                parts=[\n",
    "                    genai_types.Part.from_uri(\n",
    "                        file_uri=pdf_file.uri,\n",
    "                        mime_type=pdf_file.mime_type\n",
    "                    ),\n",
    "                    genai_types.Part.from_text(text=user_prompt)\n",
    "                ]\n",
    "            )]\n",
    "            \n",
    "            response = client.models.generate_content(\n",
    "                model=MODEL_ANALYSIS,\n",
    "                contents=contents,\n",
    "                config=genai_types.GenerateContentConfig(\n",
    "                    system_instruction=system_prompt,\n",
    "                    temperature=0.1,\n",
    "                    response_mime_type='application/json'\n",
    "                )\n",
    "            )\n",
    "            \n",
    "            # Cleanup\n",
    "            try:\n",
    "                client.files.delete(name=pdf_file.name)\n",
    "            except:\n",
    "                pass\n",
    "            \n",
    "            # Parse response\n",
    "            raw = response.text.replace('```json', '').replace('```', '').strip()\n",
    "            result = json.loads(raw)\n",
    "            \n",
    "            # Dodaj metadane\n",
    "            result['ai_model'] = MODEL_ANALYSIS\n",
    "            result['analysis_status'] = 'completed'\n",
    "            result['last_analyzed_at'] = datetime.now(timezone.utc).isoformat()\n",
    "            \n",
    "            return result\n",
    "            \n",
    "        except json.JSONDecodeError as e:\n",
    "            return {'analysis_status': 'failed', 'analysis_error': f'JSON parse: {e}'}\n",
    "        except Exception as e:\n",
    "            return {'analysis_status': 'failed', 'analysis_error': str(e)}\n",
    "\n",
    "\n",
    "analyzer = DatasheetAIAnalyzer(GEMINI_API_KEYS)\n",
    "print('✅ DatasheetAIAnalyzer gotowy')\n"
   ],
   "execution_count": null,
   "outputs": []
