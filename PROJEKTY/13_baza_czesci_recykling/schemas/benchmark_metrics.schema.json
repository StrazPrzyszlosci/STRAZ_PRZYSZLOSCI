{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Benchmark Metrics Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "variant_id",
    "variant_config",
    "run_timestamp",
    "sample_id",
    "sample_size",
    "metrics"
  ],
  "properties": {
    "variant_id": {
      "type": "string",
      "description": "Matches the variant_id from the variant configuration"
    },
    "variant_config": {
      "type": "object",
      "description": "Full variant configuration used for this run"
    },
    "run_timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the run"
    },
    "is_mock_run": {
      "type": "boolean",
      "description": "True if this was a mock/dry run without real model invocation"
    },
    "sample_id": {
      "type": "string",
      "description": "Identifier of the test sample used"
    },
    "sample_size": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of records in the test sample"
    },
    "metrics": {
      "type": "object",
      "required": [
        "true_positives",
        "false_positives",
        "false_negatives",
        "true_negatives",
        "precision",
        "recall",
        "false_positive_rate",
        "time_per_record_s",
        "cost_per_record_usd"
      ],
      "properties": {
        "true_positives": {
          "type": "integer",
          "minimum": 0
        },
        "false_positives": {
          "type": "integer",
          "minimum": 0
        },
        "false_negatives": {
          "type": "integer",
          "minimum": 0
        },
        "true_negatives": {
          "type": "integer",
          "minimum": 0
        },
        "precision": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "recall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "false_positive_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "time_per_record_s": {
          "type": "number",
          "minimum": 0
        },
        "cost_per_record_usd": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
