    "\n",
    "def extract_tags(title: str, description: str) -> list[tuple[str, str, float]]:\n",
    "    \"\"\"Extract tags from title and description using regex patterns.\n",
    "    Returns list of (tag, source, confidence) tuples.\"\"\"\n",
    "    tags = []\n",
    "    text_title = (title or \"\").lower()\n",
    "    text_desc = (description or \"\").lower()\n",
    "    # Strip HTML from description for matching\n",
    "    text_desc_clean = re.sub(r'<[^>]+>', ' ', text_desc)\n",
    "    \n",
    "    for category, patterns in TAG_PATTERNS.items():\n",
    "        for pattern in patterns:\n",
    "            # Check title first (higher confidence)\n",
    "            if re.search(pattern, text_title, re.IGNORECASE):\n",
    "                tags.append((category, 'title', 0.95))\n",
    "            # Check description (lower confidence)\n",
    "            elif re.search(pattern, text_desc_clean, re.IGNORECASE):\n",
    "                tags.append((category, 'description', 0.7))\n",
    "    \n",
    "    # Also extract individual keywords from title\n",
    "    # Split title into words, keep ones > 3 chars\n",
    "    title_words = re.findall(r'\\b[a-ząćęłńóśźż]{4,}\\b', text_title)\n",
    "    for word in title_words:\n",
    "        if word not in {'za darmo', 'darmo', 'oddam', 'oddanie', 'darmowe', 'darmowych'}:\n",
    "            tags.append((word, 'keyword', 0.5))\n",
    "    \n",
    "    return tags\n",
    "\n",
