    "    \"Accept-Language\": \"pl-PL,pl;q=0.9,en-US;q=0.8,en;q=0.7\",\n",
    "    \"Referer\": \"https://www.olx.pl/\",\n",
    "}\n",
    "OLX_HEADERS = {\n",
    "    **OLX_BROWSER_HEADERS,\n",
    "    \"Accept\": \"application/json, text/plain, */*\",\n",
    "    \"Origin\": \"https://www.olx.pl\",\n",
    "    \"X-Requested-With\": \"XMLHttpRequest\",\n",
    "}\n",
    "OLX_BLOCK_STATUS_CODES = {403, 429}\n",
    "\n",
    "# --- Target: \"Oddam za darmo\" category ---\n",
    "OLX_CATEGORY_FREE = 1151  # \"Oddam za darmo\" main category\n",
    "\n",
    "# --- Scan targets: city centers with radius ---\n",
    "# Strategy: scan multiple city centers to cover Kłodzka Valley + surroundings\n",
    "# Each center must produce <1000 results (API limit)\n",
    "SCAN_TARGETS = [\n",
    "    # (city_name, city_id, distance_km)\n",
