    "DB_PATH = OUTPUT_DIR / \"olx_market.db\"\n",
    "JSONL_PATH = OUTPUT_DIR / \"olx_offers_export.jsonl\"\n",
    "SQL_PATH = OUTPUT_DIR / \"olx_d1_import.sql\"\n",
    "REPORT_PATH = OUTPUT_DIR / \"scan_report.md\"\n",
    "\n",
    "# --- Scraper metadata ---\n",
    "SCRAPER_VERSION = \"1.0.1\"\n",
    "SCAN_BATCH_ID = datetime.now(timezone.utc).strftime(\"olx-scan-%Y%m%d-%H%M%S\")\n",
    "\n",
    "\n",
    "def olx_preflight_host(timeout: float = 5.0) -> bool:\n",
    "    \"\"\"Fast network check. In Kaggle this usually means Settings -> Internet -> On.\"\"\"\n",
    "    try:\n",
    "        with socket.create_connection((\"www.olx.pl\", 443), timeout=timeout):\n",
    "            return True\n",
    "    except OSError:\n",
    "        return False\n",
    "\n",
    "\n",
    "def warmup_olx_session(client: httpx.Client) -> bool:\n",
    "    \"\"\"Open OLX home first so the API request has normal cookies/session state.\"\"\"\n",
    "    try:\n",
    "        resp = client.get(\"https://www.olx.pl/\", headers=OLX_BROWSER_HEADERS, timeout=15.0)\n",
    "        if resp.status_code in OLX_BLOCK_STATUS_CODES:\n",
    "            print(f\"   🚫 OLX warmup blocked: HTTP {resp.status_code}\")\n",
    "            return False\n",
    "        print(f\"   ✅ OLX warmup: HTTP {resp.status_code}\")\n",
    "        return True\n",
    "    except httpx.HTTPError as e:\n",
    "        print(f\"   ⚠️ OLX warmup failed: {e}\")\n",
    "        return False\n",
    "\n",
    "\n",
    "def fetch_olx_json(client: httpx.Client, params: dict, label: str) -> Optional[dict]:\n",
    "    \"\"\"Fetch one OLX API page with retry and explicit block diagnostics.\"\"\"\n",
    "    for attempt in range(1, MAX_FETCH_ATTEMPTS + 1):\n",
    "        try:\n",
    "            resp = client.get(OLX_BASE_URL, params=params, headers=OLX_HEADERS, timeout=20.0)\n",
    "            if resp.status_code in OLX_BLOCK_STATUS_CODES:\n",
    "                wait = REQUEST_DELAY_SEC * (attempt + 1)\n",
    "                print(f\"  🚫 {label}: HTTP {resp.status_code}; retry {attempt}/{MAX_FETCH_ATTEMPTS} after warmup + {wait:.1f}s\")\n",
    "                warmup_olx_session(client)\n",
    "                time.sleep(wait)\n",
    "                continue\n",
    "            resp.raise_for_status()\n",
    "            return resp.json()\n",
    "        except json.JSONDecodeError:\n",
    "            snippet = resp.text[:200] if 'resp' in locals() else ''\n",
    "            print(f\"  ❌ {label}: OLX returned non-JSON response: {snippet!r}\")\n",
    "        except httpx.HTTPError as e:\n",
    "            wait = REQUEST_DELAY_SEC * (attempt + 1)\n",
    "            print(f\"  ⚠️ {label}: request failed ({e}); retry {attempt}/{MAX_FETCH_ATTEMPTS} in {wait:.1f}s\")\n",
    "            time.sleep(wait)\n",
    "    return None\n",
    "\n",
    "\n",
    "print(f\"✅ Config ready. Batch: {SCAN_BATCH_ID}\")\n",
    "print(f\"   Targets: {len(SCAN_TARGETS)} city centers\")\n",
    "print(f\"   Output: {OUTPUT_DIR}\")\n"
