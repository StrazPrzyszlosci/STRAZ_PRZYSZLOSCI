    "def catalog_offers(conn: sqlite3.Connection) -> dict:\n",
    "    \"\"\"FAZA 2: Process all offers and extract tags. Returns stats.\"\"\"\n",
    "    stats = {\"offers_tagged\": 0, \"tags_created\": 0}\n",
