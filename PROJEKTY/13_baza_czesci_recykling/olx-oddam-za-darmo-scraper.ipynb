    "    (\"Wrocław\",      47393, 20),   # Regional capital (limited radius)\n",
    "]\n",
    "\n",
    "# --- Rate limiting ---\n",
    "REQUEST_DELAY_SEC = 1.2       # Delay between API calls (be gentle)\n",
    "PAGE_LIMIT = 50               # Max offers per API request\n",
    "MAX_PAGES_PER_TARGET = 25     # Safety cap (25 * 50 = 1250 max per target)\n",
    "MAX_FETCH_ATTEMPTS = 3        # Retry 403/429 or transient network failures\n",
    "\n",
    "# --- Output paths ---\n",
    "OUTPUT_DIR = Path(\"/kaggle/working/olx_scraper\")\n",
