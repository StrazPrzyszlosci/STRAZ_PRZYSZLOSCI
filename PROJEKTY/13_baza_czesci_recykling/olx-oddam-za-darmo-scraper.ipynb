    "    # Get all offers that haven't been tagged yet\n",
    "    offers = conn.execute(\"\"\"\n",
    "        SELECT o.id, o.title, o.description\n",
    "        FROM olx_offers o\n",
    "        WHERE o.status = 'active'\n",
    "        AND o.id NOT IN (SELECT DISTINCT offer_id FROM olx_offer_tags)\n",
    "    \"\"\").fetchall()\n",
    "    \n",
    "    print(f\"  📝 Tagging {len(offers)} offers...\")\n",
    "    \n",
    "    for offer in offers:\n",
    "        tags = extract_tags(offer['title'], offer['description'])\n",
    "        for tag, source, confidence in tags:\n",
    "            try:\n",
    "                conn.execute(\n",
    "                    \"INSERT OR IGNORE INTO olx_offer_tags (offer_id, tag, tag_source, confidence) VALUES (?, ?, ?, ?)\",\n",
    "                    (offer['id'], tag, source, confidence)\n",
    "                )\n",
    "                stats[\"tags_created\"] += 1\n",
    "            except sqlite3.IntegrityError:\n",
    "                pass  # Duplicate tag — skip\n",
    "        \n",
    "        stats[\"offers_tagged\"] += 1\n",
    "        if stats[\"offers_tagged\"] % 100 == 0:\n",
    "            conn.commit()\n",
    "            print(f\"    ... {stats['offers_tagged']}/{len(offers)} offers tagged ({stats['tags_created']} tags)\")\n",
    "    \n",
    "    conn.commit()\n",
    "    return stats\n",
    "\n",
