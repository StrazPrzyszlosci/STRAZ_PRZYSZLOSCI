    "def generate_report(conn: sqlite3.Connection, output_path: Path, scan_stats: dict):\n",
    "    \"\"\"Generate a scan report markdown.\"\"\"\n",
    "    total_offers = conn.execute(\"SELECT COUNT(*) FROM olx_offers\").fetchone()[0]\n",
    "    active_offers = conn.execute(\"SELECT COUNT(*) FROM olx_offers WHERE status='active'\").fetchone()[0]\n",
    "    total_tags = conn.execute(\"SELECT COUNT(*) FROM olx_offer_tags\").fetchone()[0]\n",
    "    unique_tags = conn.execute(\"SELECT COUNT(DISTINCT tag) FROM olx_offer_tags\").fetchone()[0]\n",
    "    \n",
    "    with open(output_path, 'w', encoding='utf-8') as f:\n",
    "        f.write(f\"# OLX Scanner Report\\n\\n\")\n",
    "        f.write(f\"**Batch:** {SCAN_BATCH_ID}\\n\")\n",
    "        f.write(f\"**Date:** {datetime.now(timezone.utc).isoformat()}\\n\")\n",
    "        f.write(f\"**Version:** {SCRAPER_VERSION}\\n\\n\")\n",
    "        \n",
    "        f.write(f\"## Scan Summary\\n\\n\")\n",
    "        f.write(f\"| Metric | Value |\\n\")\n",
    "        f.write(f\"|--------|-------|\\n\")\n",
    "        f.write(f\"| Total offers in DB | {total_offers} |\\n\")\n",
    "        f.write(f\"| Active offers | {active_offers} |\\n\")\n",
    "        f.write(f\"| Total tags | {total_tags} |\\n\")\n",
    "        f.write(f\"| Unique tags | {unique_tags} |\\n\")\n",
    "        f.write(f\"| DB size | {DB_PATH.stat().st_size / 1024:.1f} KB |\\n\\n\")\n",
    "        \n",
    "        f.write(f\"## Per-City Stats\\n\\n\")\n",
    "        f.write(f\"| City | Scanned | New | Updated | Errors |\\n\")\n",
    "        f.write(f\"|------|---------|-----|---------|--------|\\n\")\n",
    "        for city, stats in scan_stats.items():\n",
    "            f.write(f\"| {city} | {stats['scanned']} | {stats['new']} | {stats['updated']} | {stats['errors']} |\\n\")\n",
    "        \n",
    "        f.write(f\"\\n## Top Tags\\n\\n\")\n",
    "        tag_counts = conn.execute(\"\"\"\n",
    "            SELECT tag, COUNT(*) as cnt, AVG(confidence) as avg_conf\n",
    "            FROM olx_offer_tags\n",
    "            WHERE tag_source IN ('title', 'description')\n",
    "            GROUP BY tag ORDER BY cnt DESC LIMIT 20\n",
    "        \"\"\").fetchall()\n",
    "        f.write(f\"| Tag | Count | Avg Confidence |\\n\")\n",
    "        f.write(f\"|-----|-------|---------------|\\n\")\n",
    "        for row in tag_counts:\n",
    "            f.write(f\"| {row[0]} | {row[1]} | {row[2]:.2f} |\\n\")\n",
    "        \n",
