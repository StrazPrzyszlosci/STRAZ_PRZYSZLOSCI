    "def export_to_jsonl(conn: sqlite3.Connection, output_path: Path) -> int:\n",
    "    \"\"\"Export all offers as JSONL for D1 import.\"\"\"\n",
    "    offers = conn.execute(\"SELECT * FROM olx_offers WHERE status = 'active'\").fetchall()\n",
    "    count = 0\n",
    "    with open(output_path, 'w', encoding='utf-8') as f:\n",
    "        for row in offers:\n",
    "            record = dict(row)\n",
    "            # Convert None to null for JSON\n",
    "            f.write(json.dumps(record, ensure_ascii=False, default=str) + '\\n')\n",
    "            count += 1\n",
    "    return count\n",
    "\n",
    "\n",
    "def sql_literal(value) -> str:\n",
    "    \"\"\"Render a Python value as a SQLite literal for D1 import files.\"\"\"\n",
    "    if value is None:\n",
    "        return 'NULL'\n",
    "    if isinstance(value, (int, float)):\n",
    "        return str(value)\n",
    "    return \"'\" + str(value).replace(\"'\", \"''\") + \"'\"\n",
    "\n",
    "\n",
    "def export_to_sql(conn: sqlite3.Connection, output_path: Path) -> int:\n",
    "    \"\"\"Export all offers as SQL INSERT statements for wrangler d1 import.\"\"\"\n",
    "    offers = conn.execute(\"SELECT * FROM olx_offers WHERE status = 'active'\").fetchall()\n",
    "    tags = conn.execute(\"SELECT * FROM olx_offer_tags\").fetchall()\n",
    "    batches = conn.execute(\"SELECT * FROM olx_scan_batches\").fetchall()\n",
    "    price_history = conn.execute(\"SELECT * FROM olx_price_history\").fetchall()\n",
    "    \n",
    "    count = 0\n",
    "    with open(output_path, 'w', encoding='utf-8') as f:\n",
    "        f.write(\"-- OLX Parts Market D1 Import\\n\")\n",
    "        f.write(f\"-- Generated: {datetime.now(timezone.utc).isoformat()}\\n\")\n",
    "        f.write(f\"-- Batch: {SCAN_BATCH_ID}\\n\\n\")\n",
    "        \n",
    "        # Offers\n",
    "        for row in offers:\n",
    "            cols = [k for k in row.keys() if row[k] is not None]\n",
    "            col_str = \", \".join(cols)\n",
    "            val_str = \", \".join(sql_literal(row[k]) for k in cols)\n",
    "            f.write(f\"INSERT OR REPLACE INTO olx_offers ({col_str}) VALUES ({val_str});\\n\")\n",
    "            count += 1\n",
    "        \n",
    "        f.write(f\"\\n-- Tags ({len(tags)} records)\\n\")\n",
    "        for row in tags:\n",
    "            cols = [k for k in row.keys() if row[k] is not None]\n",
    "            col_str = \", \".join(cols)\n",
    "            val_str = \", \".join(sql_literal(row[k]) for k in cols)\n",
    "            f.write(f\"INSERT OR IGNORE INTO olx_offer_tags ({col_str}) VALUES ({val_str});\\n\")\n",
    "        \n",
    "        f.write(f\"\\n-- Scan Batches ({len(batches)} records)\\n\")\n",
    "        for row in batches:\n",
    "            cols = [k for k in row.keys() if row[k] is not None]\n",
    "            col_str = \", \".join(cols)\n",
    "            val_str = \", \".join(sql_literal(row[k]) for k in cols)\n",
    "            f.write(f\"INSERT OR REPLACE INTO olx_scan_batches ({col_str}) VALUES ({val_str});\\n\")\n",
    "        \n",
    "        f.write(f\"\\n-- Price History ({len(price_history)} records)\\n\")\n",
    "        for row in price_history:\n",
    "            cols = [k for k in row.keys() if row[k] is not None]\n",
    "            col_str = \", \".join(cols)\n",
    "            val_str = \", \".join(sql_literal(row[k]) for k in cols)\n",
    "            f.write(f\"INSERT OR IGNORE INTO olx_price_history ({col_str}) VALUES ({val_str});\\n\")\n",
    "    \n",
    "    return count\n",
